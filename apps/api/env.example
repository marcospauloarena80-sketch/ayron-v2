# AYRON API — Environment Variables Reference
# Copy to apps/api/.env and adjust

# Database
DATABASE_URL=postgresql://ayron:ayron@localhost:5432/ayron_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=ayron-dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# App
PORT=4000
NODE_ENV=development

# ---- MinIO — DEV HOST ----
# (Docker MinIO accessible on localhost)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=ayron_minio
MINIO_SECRET_KEY=ayron_minio_password
MINIO_BUCKET=ayron-docs
MINIO_REGION=us-east-1

# ---- MinIO — DOCKER / VPS ----
# Backend and MinIO share the same compose network
# MINIO_ENDPOINT=http://minio:9000

# ---- Puppeteer — DEV (uses bundled Chromium) ----
# Leave empty to use puppeteer's bundled Chromium
# PUPPETEER_EXECUTABLE_PATH=
# PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox
# PDF_TIMEOUT_MS=25000

# ---- Puppeteer — VPS/Container (use system Chromium) ----
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage,--disable-gpu,--no-zygote,--single-process
# PDF_TIMEOUT_MS=30000
