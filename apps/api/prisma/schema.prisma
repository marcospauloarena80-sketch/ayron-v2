// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 16 — INTEGRAÇÕES FUTURAS (V19)
// ─────────────────────────────────────────────────────────────────────────────

model WearableDataPoint {
  id             String   @id @default(uuid())
  patient_id     String
  clinic_id      String
  source         String // APPLE_HEALTH | GOOGLE_FIT | OURA | DEXCOM
  metric_type    String // HRV | HEART_RATE | SLEEP_SCORE | GLUCOSE
  value          Float
  unit           String?
  recorded_at    DateTime
  is_anomaly     Boolean  @default(false)
  clinical_notes String?
  created_at     DateTime @default(now())

  patient Patient @relation(fields: [patient_id], references: [id], onDelete: Restrict)
  clinic  Clinic  @relation(fields: [clinic_id], references: [id], onDelete: Restrict)

  @@index([patient_id, metric_type, recorded_at(sort: Desc)])
  @@map("wearable_data_points")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 17 — CONSENTIMENTO LGPD (PatientConsentRecord)
// Granular: paciente controla quais dados podem ser usados e por quem
// ─────────────────────────────────────────────────────────────────────────────

enum ConsentType {
  TREATMENT_DATA // uso de dados para tratamento clínico
  MARKETING // comunicações e conteúdo educativo
  RESEARCH_ANONYMOUS // pesquisa com dados anonimizados
  THIRD_PARTY_SHARING // compartilhamento com terceiros (labs, convênios)
  AI_PROCESSING // processamento por IA para sugestões
  WEARABLE_INTEGRATION // recebimento de dados de dispositivos
  TELEMEDICINE // consultas por vídeo
}

enum ConsentStatus {
  GRANTED
  REVOKED
  EXPIRED
}

model PatientConsentRecord {
  id           String        @id @default(uuid())
  clinic_id    String
  patient_id   String
  consent_type ConsentType
  status       ConsentStatus @default(GRANTED)
  granted_at   DateTime      @default(now())
  expires_at   DateTime? // null = sem expiração
  revoked_at   DateTime?
  ip_address   String?
  channel      String        @default("WEB") // WEB | APP | PAPER | VERBAL
  notes        String?
  document_url String? // PDF do termo assinado digitalmente

  clinic  Clinic  @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  patient Patient @relation(fields: [patient_id], references: [id], onDelete: Restrict)

  @@unique([patient_id, consent_type, clinic_id])
  @@index([clinic_id, patient_id, status])
  @@index([clinic_id, consent_type, status])
  @@map("patient_consent_records")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 18 — ORÇAMENTOS (Financeiro submódulo)
// ─────────────────────────────────────────────────────────────────────────────

enum BudgetStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

model Budget {
  id              String       @id @default(uuid())
  clinic_id       String
  patient_id      String
  professional_id String?
  status          BudgetStatus @default(DRAFT)
  total_amount    Decimal      @db.Decimal(12, 2)
  discount        Decimal      @default(0) @db.Decimal(12, 2)
  notes           String?
  valid_until     DateTime?
  converted_at    DateTime?
  appointment_id  String?
  receivable_id   String?
  items           Json         @default("[]")
  created_by      String
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  clinic  Clinic  @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  patient Patient @relation(fields: [patient_id], references: [id], onDelete: Restrict)

  @@index([clinic_id, status, created_at])
  @@index([patient_id, status])
  @@map("budgets")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 19 — TEMPLATES DE MENSAGEM (Comunicação)
// ─────────────────────────────────────────────────────────────────────────────

model MessageTemplate {
  id         String   @id @default(uuid())
  clinic_id  String
  name       String
  content    String
  channel    String   @default("INTERNAL")
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Cascade)

  @@index([clinic_id, channel, is_active])
  @@map("message_templates")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 20 — PRONTUÁRIO ENDÓCRINO (Métricas, Protocolos, Implantes)
// Sprint 2 — Endocrinologia & Alta Performance
// ─────────────────────────────────────────────────────────────────────────────

enum ProtocolType {
  EMAGRECIMENTO
  GANHO_MASSA
  IMPLANTE_HORMONAL
  SOROTERAPIA
  LONGEVIDADE
  NUTRICIONAL
  PERSONALIZADO
}

enum ProtocolStatus {
  ATIVO
  PAUSADO
  FINALIZADO
  SUSPENSO
}

model PatientMetrics {
  id             String    @id @default(uuid())
  clinic_id      String
  patient_id     String
  appointment_id String?
  recorded_by    String    // professional_id

  weight_kg       Decimal? @db.Decimal(5, 2)
  height_cm       Decimal? @db.Decimal(5, 1)
  bmi             Decimal? @db.Decimal(5, 2)
  body_fat_pct    Decimal? @db.Decimal(5, 2)
  lean_mass_kg    Decimal? @db.Decimal(5, 2)
  waist_cm        Decimal? @db.Decimal(5, 1)
  bp_systolic       Int?
  bp_diastolic      Int?
  heart_rate        Int?
  is_bioimpedance   Boolean  @default(false)
  visceral_fat      Decimal? @db.Decimal(5, 2)
  bmr               Int?
  muscle_mass_kg    Decimal? @db.Decimal(5, 2)
  attachment_key    String?
  extraction_raw    Json?
  notes             String?

  created_at DateTime  @default(now())
  deleted_at DateTime?

  clinic      Clinic       @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  patient     Patient      @relation(fields: [patient_id], references: [id], onDelete: Restrict)
  appointment Appointment? @relation(fields: [appointment_id], references: [id], onDelete: SetNull)

  @@index([clinic_id, patient_id])
  @@index([patient_id, created_at(sort: Desc)])
  @@map("patient_metrics")
}

model TreatmentProtocol {
  id          String         @id @default(uuid())
  clinic_id   String
  patient_id  String
  type        ProtocolType
  name        String
  description String?
  start_date  DateTime
  end_date    DateTime?
  status      ProtocolStatus @default(ATIVO)
  notes       String?
  created_by  String
  total_sessions    Int?
  frequency         ProtocolFrequency?
  preferred_weekday Int?
  preferred_time    String?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  clinic  Clinic  @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  patient Patient @relation(fields: [patient_id], references: [id], onDelete: Restrict)

  @@index([clinic_id, patient_id, status])
  @@map("treatment_protocols")
}

model HormoneImplant {
  id               String    @id @default(uuid())
  clinic_id        String
  patient_id       String
  appointment_id   String?
  applied_by       String    // professional_id

  hormone_type     String
  dosage_mg        Decimal   @db.Decimal(8, 2)
  application_date DateTime
  lot_number       String?
  next_change_date DateTime?
  site             String?
  observations     String?

  created_at DateTime  @default(now())
  deleted_at DateTime?

  clinic      Clinic       @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  patient     Patient      @relation(fields: [patient_id], references: [id], onDelete: Restrict)
  appointment Appointment? @relation(fields: [appointment_id], references: [id], onDelete: SetNull)

  @@index([clinic_id, patient_id])
  @@index([next_change_date])
  @@map("hormone_implants")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA COGNITIVA — ALERTAS INTELIGENTES
// ─────────────────────────────────────────────────────────────────────────────

model Alert {
  id                   String          @id @default(uuid())
  clinic_id            String
  patient_id           String?
  appointment_id       String?
  rule_key             String
  category             AlertCategory
  severity             AlertSeverity
  owner_role_target    AlertOwnerRole  @default(ALL)
  title                String
  message              String
  rationale            Json            // string[] bullets
  suggested_actions    Json            // {key:string, label:string}[]
  status               AlertStatus     @default(OPEN)
  due_at               DateTime?
  snoozed_until        DateTime?
  dedup_key            String          // prevent duplicates: clinic+patient+rule+window
  score                Int             @default(0)
  last_triggered_at    DateTime?       // for 12h cooldown
  created_at           DateTime        @default(now())
  resolved_at          DateTime?
  resolved_by_user_id  String?
  resolution_note      String?
  metadata             Json?
  deleted_at           DateTime?

  clinic      Clinic       @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  patient     Patient?     @relation(fields: [patient_id], references: [id], onDelete: SetNull)
  action_logs AlertActionLog[]

  @@unique([dedup_key])
  @@index([clinic_id, status, severity])
  @@index([clinic_id, owner_role_target, status])
  @@index([clinic_id, patient_id])
  @@index([clinic_id, created_at])
  @@map("alerts")
}

model AlertActionLog {
  id         String   @id @default(uuid())
  alert_id   String
  clinic_id  String
  user_id    String?
  action     String
  note       String?
  created_at DateTime @default(now())

  alert Alert @relation(fields: [alert_id], references: [id], onDelete: Cascade)

  @@index([alert_id])
  @@index([clinic_id, created_at])
  @@map("alert_action_logs")
}

model AlertRuleConfig {
  id         String   @id @default(uuid())
  clinic_id  String
  rule_key   String
  enabled    Boolean  @default(true)
  params     Json     @default("{}")
  updated_at DateTime @updatedAt
  created_at DateTime @default(now())

  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Cascade)

  @@unique([clinic_id, rule_key])
  @@index([clinic_id])
  @@map("alert_rule_configs")
}

model PatientCognitiveScore {
  id                       String    @id @default(uuid())
  clinic_id                String
  patient_id               String    @unique
  clinical_stability_score Int       @default(0)
  retention_risk_score     Int       @default(0)
  composite_risk_score     Int       @default(0)
  calculated_at            DateTime  @default(now())
  explanation_json         Json      @default("{}")
  score_previous           Int       @default(0)
  score_trend              String    @default("FLAT")
  current_band             String    @default("GREEN")
  consecutive_hits_red     Int       @default(0)
  consecutive_hits_yellow  Int       @default(0)
  band_locked_until        DateTime?
  no_show_probability      Int       @default(0)
  dropout_risk_30d         Int       @default(0)
  clinical_trend           String    @default("STABLE")

  clinic  Clinic  @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patient_id], references: [id], onDelete: Cascade)

  @@unique([clinic_id, patient_id])
  @@index([clinic_id, composite_risk_score])
  @@map("patient_cognitive_scores")
}

model PlaybookConfig {
  id         String   @id @default(uuid())
  clinic_id  String   @unique
  enabled    Boolean  @default(true)
  thresholds Json     @default("{\"red\":70,\"yellow\":40}")
  actions    Json     @default("{}")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Cascade)

  @@map("playbook_configs")
}

model Task {
  id                   String       @id @default(uuid())
  clinic_id            String
  patient_id           String?
  appointment_id       String?
  source               TaskSource   @default(MANUAL)
  source_ref_id        String?
  rule_key             String?
  type                 TaskType
  priority             TaskPriority @default(MEDIUM)
  title                String
  message              String
  due_at               DateTime
  status               TaskStatus   @default(OPEN)
  owner_role_target    AlertOwnerRole
  assigned_user_id     String?
  snoozed_until        DateTime?
  created_at           DateTime     @default(now())
  completed_at         DateTime?
  completed_by_user_id String?
  resolution_note      String?

  clinic  Clinic   @relation(fields: [clinic_id], references: [id], onDelete: Cascade)
  patient Patient? @relation(fields: [patient_id], references: [id])
  logs    TaskActionLog[]

  @@index([clinic_id, status, due_at])
  @@index([clinic_id, priority])
  @@index([clinic_id, patient_id])
  @@map("tasks")
}

model TaskActionLog {
  id         String         @id @default(uuid())
  clinic_id  String
  task_id    String
  user_id    String
  action     TaskActionType
  note       String?
  created_at DateTime       @default(now())

  task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([clinic_id, task_id])
  @@map("task_action_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA FINANCEIRO COMPLETO
// ─────────────────────────────────────────────────────────────────────────────

model FinancialAccount {
  id         String               @id @default(uuid())
  clinic_id  String
  name       String
  type       FinancialAccountType @default(CASH)
  currency   String               @default("BRL")
  is_active  Boolean              @default(true)
  created_at DateTime             @default(now())
  deleted_at DateTime?

  clinic         Clinic         @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  ledger_entries LedgerEntry[]
  ledger_entries_to LedgerEntry[] @relation("LedgerAccountTo")

  @@index([clinic_id, is_active])
  @@map("financial_accounts")
}

model Counterparty {
  id          String          @id @default(uuid())
  clinic_id   String
  type        CounterpartyType @default(OTHER)
  patient_id  String?
  name        String
  document_id String?
  created_at  DateTime        @default(now())
  deleted_at  DateTime?

  clinic   Clinic   @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  payables Payable[]

  @@index([clinic_id, type])
  @@map("counterparties")
}

model Receivable {
  id             String          @id @default(uuid())
  clinic_id      String
  patient_id     String
  appointment_id String?
  budget_id      String?
  status         ReceivableStatus @default(OPEN)
  issue_date     DateTime        @default(now())
  due_date       DateTime
  total_amount   Decimal         @db.Decimal(12, 2)
  paid_amount    Decimal         @default(0) @db.Decimal(12, 2)
  description    String?
  payment_terms  Json?
  notes          String?
  created_by     String
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  deleted_at     DateTime?

  clinic      Clinic       @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  patient     Patient      @relation(fields: [patient_id], references: [id], onDelete: Restrict)
  appointment Appointment? @relation(fields: [appointment_id], references: [id], onDelete: SetNull)
  ledger_entries LedgerEntry[]

  @@index([clinic_id, status, due_date])
  @@index([clinic_id, patient_id])
  @@index([appointment_id])
  @@map("receivables")
}

model Payable {
  id               String          @id @default(uuid())
  clinic_id        String
  counterparty_id  String?
  category         PayableCategory @default(OTHER)
  status           PayableStatus   @default(OPEN)
  issue_date       DateTime        @default(now())
  due_date         DateTime
  amount           Decimal         @db.Decimal(12, 2)
  description      String?
  notes            String?
  attachment_key   String?
  created_by       String
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  deleted_at       DateTime?

  clinic       Clinic        @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  counterparty Counterparty? @relation(fields: [counterparty_id], references: [id], onDelete: SetNull)
  ledger_entries LedgerEntry[]

  @@index([clinic_id, status, due_date])
  @@index([clinic_id, category])
  @@map("payables")
}

model LedgerEntry {
  id              String          @id @default(uuid())
  clinic_id       String
  type            LedgerEntryType
  account_id      String?
  account_to_id   String?
  reference_type  String?
  reference_id    String?
  receivable_id   String?
  payable_id      String?
  amount          Decimal         @db.Decimal(12, 2)
  method          String          @default("OTHER")
  occurred_at     DateTime        @default(now())
  description     String?
  created_by      String
  created_at      DateTime        @default(now())

  clinic      Clinic            @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  account     FinancialAccount? @relation(fields: [account_id], references: [id], onDelete: SetNull)
  account_to  FinancialAccount? @relation("LedgerAccountTo", fields: [account_to_id], references: [id], onDelete: SetNull)
  receivable  Receivable?       @relation(fields: [receivable_id], references: [id], onDelete: SetNull)
  payable     Payable?          @relation(fields: [payable_id], references: [id], onDelete: SetNull)

  @@index([clinic_id, type, occurred_at])
  @@index([clinic_id, receivable_id])
  @@index([clinic_id, payable_id])
  @@map("ledger_entries")
}

model FinancialActionLog {
  id          String   @id @default(uuid())
  clinic_id   String
  user_id     String?
  entity_type String
  entity_id   String
  action      String
  amount      Decimal? @db.Decimal(12, 2)
  note        String?
  created_at  DateTime @default(now())

  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Restrict)

  @@index([clinic_id, entity_type, entity_id])
  @@index([clinic_id, created_at])
  @@map("financial_action_logs")
}
