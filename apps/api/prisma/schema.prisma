}

model NotificationLog {
  id         String    @id @default(uuid())
  clinic_id  String
  patient_id String?
  user_id    String?
  channel    String // WEBSOCKET | PUSH | EMAIL | WHATSAPP
  event_type String
  content    Json
  sent       Boolean   @default(false)
  sent_at    DateTime?
  error      String?
  created_at DateTime  @default(now())

  clinic  Clinic   @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  patient Patient? @relation(fields: [patient_id], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([clinic_id, sent, created_at])
  @@map("notification_logs")
