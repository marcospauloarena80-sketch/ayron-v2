// ─────────────────────────────────────────────────────────────────────────────
// AYRON — Schema Master v1.0  (AUDITADO E CORRIGIDO)
// PostgreSQL + pgvector | Multi-tenant | Event-driven | Cognitive-ready
// Fixes: onDelete em todas FKs, modelo Professional, CPF partial-index-only,
//        Decimal(12,2) universal, ClinicalRecord → Professional
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
