// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 1 — IDENTIDADE E ACESSO
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id         String    @id @default(uuid())
  name       String
  document   String?
  plan_tier  String    @default("CORE")
  is_active  Boolean   @default(true)
  settings   Json?     @default("{}")
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  clinics Clinic[]
  users   User[]

  @@index([is_active])
  @@map("organizations")
}

model Clinic {
  id              String    @id @default(uuid())
  organization_id String
  name            String
  document        String?
  address         Json?
  phone           String?
  email           String?
  timezone        String    @default("America/Sao_Paulo")
  specialty       String?
  settings        Json      @default("{}")
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  organization           Organization           @relation(fields: [organization_id], references: [id], onDelete: Restrict)
  users                  User[]
  patients               Patient[]
  professionals          Professional[]
  appointments           Appointment[]
  clinical_records       ClinicalRecord[]
  exams                  Exam[]
  documents              Document[]
  transactions           Transaction[]
  inventory_items        InventoryItem[]
  events                 Event[]
  decision_proposals     DecisionProposal[]
  cognitive_memory       CognitiveMemory[]
  behavior_patterns      BehaviorPattern[]
  digital_twin_snapshots DigitalTwinSnapshot[]
  feature_flags          FeatureFlag[]
  communication_channels CommunicationChannel[]
  services               Service[]
  daily_closings         DailyClosing[]
  clinic_metrics         ClinicMetricDaily[]
  ai_action_logs         AiActionLog[]
  notification_logs      NotificationLog[]
  wearable_data_points   WearableDataPoint[]
  waitlist_entries       WaitlistEntry[]
  alerts                 Alert[]
  cognitive_scores       PatientCognitiveScore[]
  tasks                  Task[]
  alert_rule_configs     AlertRuleConfig[]
  playbook_config        PlaybookConfig?
  consent_records        PatientConsentRecord[]
  budgets                Budget[]
  message_templates      MessageTemplate[]
  patient_metrics        PatientMetrics[]
  treatment_protocols    TreatmentProtocol[]
  hormone_implants       HormoneImplant[]
  financial_accounts     FinancialAccount[]
  counterparties         Counterparty[]
  receivables            Receivable[]
  payables               Payable[]
  ledger_entries         LedgerEntry[]
  financial_action_logs  FinancialActionLog[]
  suppliers              Supplier[]
  purchase_orders        PurchaseOrder[]
  inventory_reservations InventoryReservation[]
  inventory_losses       InventoryLoss[]
  inventory_audit_logs   InventoryAuditLog[]

  @@index([organization_id, is_active])
  @@map("clinics")
}

model User {
  id              String    @id @default(uuid())
  organization_id String
  clinic_id       String
  name            String
  email           String
  password_hash   String
  role            UserRole
  permissions     Json      @default("{}")
  is_active       Boolean   @default(true)
  last_login_at   DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  organization       Organization           @relation(fields: [organization_id], references: [id], onDelete: Restrict)
  clinic             Clinic                 @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  professional       Professional?
  sessions           Session[]
  audit_logs         AuditLog[]
  approved_proposals DecisionProposal[]     @relation("Approver")
  documents          Document[]             @relation("DocumentCreator")
  documents_signed   Document[]             @relation("DocumentSigner")
  signed_documents   DocumentSignature[]
  messages_sent      CommunicationMessage[]
  notification_logs  NotificationLog[]

  @@unique([email, clinic_id])
  @@index([clinic_id, role, is_active])
  @@index([email])
  @@map("users")
}

model Session {
  id         String   @id @default(uuid())
  user_id    String
  clinic_id  String
  token_hash String   @unique
  ip_address String?
  user_agent String?
  expires_at DateTime
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, expires_at])
  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 1b — PROFISSIONAIS (entidade separada de Users)
// Decisão arquitetural congelada: permite médicos externos sem login
// ─────────────────────────────────────────────────────────────────────────────

model Professional {
  id         String    @id @default(uuid())
  clinic_id  String
  user_id    String?   @unique // link opcional a User (médico com acesso ao sistema)
  name       String
  specialty  String?
  crm        String? // Conselho Regional de Medicina
  crm_state  String? // UF do CRM
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  clinic           Clinic                 @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  user             User?                  @relation(fields: [user_id], references: [id], onDelete: SetNull)
  appointments     Appointment[]
  clinical_records ClinicalRecord[]
  schedules        ProfessionalSchedule[]

  @@index([clinic_id, is_active])
  @@map("professionals")
}

model ProfessionalSchedule {
  id              String   @id @default(uuid())
  professional_id String
  clinic_id       String
  day_of_week     Int // 0=Dom … 6=Sáb
  start_time      String // "08:00"
  end_time        String // "18:00"
  slot_duration   Int      @default(30) // minutos
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  professional Professional @relation(fields: [professional_id], references: [id], onDelete: Cascade)

  @@unique([professional_id, day_of_week])
  @@index([clinic_id, day_of_week])
  @@map("professional_schedules")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 2 — PACIENTES (CRM CLÍNICO)
// CPF único gerenciado APENAS via partial index SQL (WHERE deleted_at IS NULL)
// O @@unique do Prisma foi REMOVIDO intencionalmente para suportar soft delete
// ─────────────────────────────────────────────────────────────────────────────

model Patient {
  id               String                       @id @default(uuid())
  clinic_id        String
  full_name        String
  birth_date       DateTime
  sex              String // M | F | OTHER
  cpf              String? // stored encrypted as <iv_hex>:<cipher_hex>
  cpf_search_hash  String? // SHA-256 of normalized CPF for lookup
  rg               String?
  nationality      String    @default("BR")
  foreign_doc_type  String?
  foreign_doc_number String?
  phone            String  // stored encrypted
  email            String?
  address          Json?
  insurance        Json?
  preferences      Json?
  risk_score       Float                        @default(0)
  risk_level       PatientRiskLevel             @default(PREVENTIVO)
  current_status   PatientStatus                @default(NOVA_LEAD)
  // cognitive_vector Unsupported("vector(1536)")? -- requires pgvector, deferred
  tags             PatientTag[]                 @default([])
  tier             String?                      // BRONZE | SILVER | GOLD | VIP | PLATINA | DIAMANTE
  origin           String?                      // tipo_contato/conheceu_por canalizado
  referred_by      String?                      // indicado_por (free-text)
  metadata         Json?                        // empresa, referencia, estado_civil, profissao, etc.
  lgpd_consent     Boolean                      @default(false)
  lgpd_consent_at  DateTime?
  last_appointment_at DateTime?
  notes            String?
  is_active        Boolean                      @default(true)
  created_at       DateTime                     @default(now())
  updated_at       DateTime                     @updatedAt
  deleted_at       DateTime?

  clinic            Clinic                 @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  status_history    PatientStatusHistory[]
  appointments      Appointment[]
  clinical_records  ClinicalRecord[]
  exams             Exam[]
  documents         Document[]
  transactions      Transaction[]
  cognitive_memory  CognitiveMemory[]
  form_responses    FormResponse[]
  notification_logs NotificationLog[]
  wearable_data     WearableDataPoint[]
  consent_records   PatientConsentRecord[]
  budgets           Budget[]
  patient_metrics   PatientMetrics[]
  treatment_protocols TreatmentProtocol[]
  hormone_implants  HormoneImplant[]
  waitlist_entries  WaitlistEntry[]
  alerts            Alert[]
  cognitive_score   PatientCognitiveScore?
  tasks             Task[]
  receivables       Receivable[]

  @@index([clinic_id, cpf]) // para busca por CPF (partial index cuida da unicidade)
  @@index([clinic_id, current_status])
  @@index([clinic_id, risk_level])
  @@index([clinic_id, is_active])
  @@map("patients")
}

model PatientStatusHistory {
  id          String         @id @default(uuid())
  patient_id  String
  clinic_id   String
  from_status PatientStatus?
  to_status   PatientStatus
  changed_by  String // user_id
  reason      String?
  created_at  DateTime       @default(now())

  patient Patient @relation(fields: [patient_id], references: [id], onDelete: Restrict)

  @@index([patient_id, created_at])
  @@map("patient_status_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 3 — AGENDA INTELIGENTE
// ─────────────────────────────────────────────────────────────────────────────

model Service {
  id           String   @id @default(uuid())
  clinic_id    String
  name         String
  description  String?
  category     String?
  duration_min Int      @default(30)
  price              Decimal? @db.Decimal(12, 2)
  color              String?
  is_active          Boolean  @default(true)
  requires_document  Boolean  @default(false)
  can_be_recurring   Boolean  @default(false)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  clinic       Clinic        @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  appointments Appointment[]

  @@index([clinic_id, is_active])
  @@map("services")
}

model Appointment {
  id                  String            @id @default(uuid())
  clinic_id           String
  patient_id          String
  professional_id     String // referencia professionals.id (não users)
  service_id          String?
  type                AppointmentType   @default(CONSULTATION)
  status              AppointmentStatus @default(SCHEDULED)
  start_time          DateTime
  end_time            DateTime
  checked_in_at         DateTime?
  checked_out_at        DateTime?
  started_at            DateTime?
  finalized_at          DateTime?
  finalization_note     String?
  return_scheduled      Boolean           @default(false)
  return_exception_note String?
  kanban_stage          String?
  stage_skipped_reason  String?
  protocol_id           String?
  notes               String?
  cancellation_reason String?
  is_telemedicine     Boolean           @default(false)
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt
  deleted_at          DateTime?

  clinic           Clinic           @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  patient          Patient          @relation(fields: [patient_id], references: [id], onDelete: Restrict)
  professional     Professional     @relation(fields: [professional_id], references: [id], onDelete: Restrict)
  service          Service?         @relation(fields: [service_id], references: [id], onDelete: SetNull)
  clinical_records ClinicalRecord[]
  transactions     Transaction[]
  patient_metrics  PatientMetrics[]
  hormone_implants HormoneImplant[]
  documents        Document[]
  receivables      Receivable[]

  @@index([clinic_id, start_time])
  @@index([clinic_id, status, start_time])
  @@index([patient_id, start_time])
  @@index([professional_id, start_time])
  @@map("appointments")
}

model WaitlistEntry {
  id                    String             @id @default(uuid())
  clinic_id             String
  patient_id            String
  service_id            String?
  professional_id       String?
  priority              Int                @default(0)
  priority_score        Int                @default(0)
  reason                WaitlistReason     @default(NEW_VISIT)
  status                WaitlistEntryStatus @default(OPEN)
  preferred_days_json   Json?
  preferred_shift       String?
  preferred_window_start String?
  preferred_window_end   String?
  notes                 String?
  created_at            DateTime           @default(now())
  resolved_at           DateTime?

  clinic  Clinic  @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  patient Patient @relation(fields: [patient_id], references: [id], onDelete: Restrict)

  @@index([clinic_id, status, priority_score])
  @@index([clinic_id, resolved_at, priority])
  @@map("waitlist_entries")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 4 — PRONTUÁRIO E EXAMES
// ─────────────────────────────────────────────────────────────────────────────

model ClinicalRecord {
  id              String    @id @default(uuid())
  clinic_id       String
  patient_id      String
  appointment_id  String?
  professional_id String // referencia professionals.id
  transcription   String?
  structured_data Json      @default("{}")
  summary_ai      String?
  voice_file_url  String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  clinic       Clinic       @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  patient      Patient      @relation(fields: [patient_id], references: [id], onDelete: Restrict)
  appointment  Appointment? @relation(fields: [appointment_id], references: [id], onDelete: SetNull)
  professional Professional @relation(fields: [professional_id], references: [id], onDelete: Restrict)

  @@index([clinic_id, patient_id, created_at])
  @@map("clinical_records")
}

model Exam {
  id                String    @id @default(uuid())
  clinic_id         String
  patient_id        String
  exam_date         DateTime
  laboratory        String?
  file_url          String?
  ocr_raw           String?
  processing_status String    @default("PENDING")
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?

  clinic  Clinic       @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  patient Patient      @relation(fields: [patient_id], references: [id], onDelete: Restrict)
  markers ExamMarker[]

  @@index([clinic_id, patient_id, exam_date])
  @@map("exams")
}

model ExamMarker {
  id                String           @id @default(uuid())
  exam_id           String
  patient_id        String
  marker_name       String
  standardized_name String?
  value             Float
  unit              String?
  ideal_min         Float?
  ideal_max         Float?
  functional_min    Float?
  functional_max    Float?
  status            ExamMarkerStatus
  trend             String? // IMPROVING | STABLE | WORSENING
  created_at        DateTime         @default(now())

  exam Exam @relation(fields: [exam_id], references: [id], onDelete: Cascade)

  @@index([patient_id, standardized_name, created_at(sort: Desc)])
  @@index([exam_id])
  @@map("exam_markers")
}

model BiomarkerReference {
  id                String   @id @default(uuid())
  clinic_id         String
  standardized_name String
  unit              String?
  ideal_min         Float?
  ideal_max         Float?
  functional_min    Float?
  functional_max    Float?
  notes             String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@unique([clinic_id, standardized_name])
  @@map("biomarker_references")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 5 — DOCUMENTOS MÉDICOS
// ─────────────────────────────────────────────────────────────────────────────

model DocumentTemplate {
  id         String       @id @default(uuid())
  clinic_id  String
  name       String
  type       DocumentType
  content    String
  is_active  Boolean      @default(true)
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt

  documents Document[]

  @@index([clinic_id, type, is_active])
  @@map("document_templates")
}

model Document {
  id                       String         @id @default(uuid())
  clinic_id                String
  patient_id               String
  appointment_id           String?
  created_by               String
  signed_by                String?
  template_id              String?
  type                     DocumentType
  status                   DocumentStatus @default(DRAFT)
  title                    String
  content                  String
  document_hash            String?
  pdf_object_key           String?
  validated_pdf_object_key String?
  file_url                 String?
  metadata                 Json?          @default("{}")
  signed_at                DateTime?
  locked_at                DateTime?
  created_at               DateTime       @default(now())
  updated_at               DateTime       @updatedAt
  deleted_at               DateTime?

  clinic      Clinic             @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  patient     Patient            @relation(fields: [patient_id], references: [id], onDelete: Restrict)
  creator     User               @relation("DocumentCreator", fields: [created_by], references: [id], onDelete: Restrict)
  signer      User?              @relation("DocumentSigner", fields: [signed_by], references: [id], onDelete: SetNull)
  template    DocumentTemplate?  @relation(fields: [template_id], references: [id], onDelete: SetNull)
  appointment Appointment?       @relation(fields: [appointment_id], references: [id], onDelete: SetNull)
  signatures  DocumentSignature[]

  @@index([clinic_id, patient_id, status])
  @@index([clinic_id, appointment_id])
  @@index([clinic_id, type, created_at])
  @@map("documents")
}

model DocumentSignature {
  id          String   @id @default(uuid())
  document_id String
  signed_by   String // user_id
  signature   String
  signed_at   DateTime @default(now())
  ip_address  String?

  document Document @relation(fields: [document_id], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [signed_by], references: [id], onDelete: Restrict)

  @@map("document_signatures")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 6 — FINANCEIRO
// ─────────────────────────────────────────────────────────────────────────────

model Transaction {
  id              String            @id @default(uuid())
  clinic_id       String
  patient_id      String?
  appointment_id  String?
  type            TransactionType
  status          TransactionStatus @default(PENDING)
  amount          Decimal           @db.Decimal(12, 2)
  payment_method  PaymentMethod?
  description     String?
  reference_code  String?
  due_date        DateTime?
  paid_at         DateTime?
  category        String?
  insurance_claim Json?
  created_by      String? // user_id
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  deleted_at      DateTime?

  clinic      Clinic       @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  patient     Patient?     @relation(fields: [patient_id], references: [id], onDelete: SetNull)
  appointment Appointment? @relation(fields: [appointment_id], references: [id], onDelete: SetNull)

  @@index([clinic_id, status, due_date])
  @@index([clinic_id, type, created_at])
  @@map("transactions")
}

model DailyClosing {
  id                     String   @id @default(uuid())
  clinic_id              String
  closing_date           DateTime
  total_revenue          Decimal  @db.Decimal(12, 2)
  total_expenses         Decimal  @db.Decimal(12, 2)
  net_result             Decimal  @db.Decimal(12, 2)
  appointments_total     Int
  appointments_completed Int
  closing_summary        Json     @default("{}")
  closed_by              String // user_id
  closed_at              DateTime @default(now())
  has_pendencies         Boolean  @default(false)

  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Restrict)

  @@unique([clinic_id, closing_date])
  @@map("daily_closings")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 7 — ESTOQUE
// ─────────────────────────────────────────────────────────────────────────────

model InventoryItem {
  id                   String              @id @default(uuid())
  clinic_id            String
  name                 String
  technical_name       String?
  internal_code        String?
  qr_code              String?
  category             String?
  subcategory          String?
  manufacturer         String?
  description          String?
  unit                 String              @default("UN")
  quantity             Int                 @default(0)
  minimum_level        Int                 @default(0)
  ideal_stock          Int                 @default(0)
  max_stock            Int                 @default(0)
  unit_cost            Decimal?            @db.Decimal(12, 2)
  average_cost         Decimal?            @db.Decimal(12, 2)
  barcode              String?
  location             String?
  storage_sector       String?
  temperature_min      Float?
  temperature_max      Float?
  expiry_date          DateTime?
  batch_number         String?
  supplier_id          String?
  secondary_supplier_id String?
  photo_url            String?
  status               InventoryItemStatus @default(ACTIVE)
  is_active            Boolean             @default(true)
  consumption_30d      Float               @default(0)
  consumption_90d      Float               @default(0)
  lead_time_days       Int                 @default(1)
  days_remaining       Int?
  abc_class            String?
  risk_score           Int                 @default(0)
  last_counted_at      DateTime?
  created_at           DateTime            @default(now())
  updated_at           DateTime            @updatedAt
  deleted_at           DateTime?

  clinic            Clinic                @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  supplier          Supplier?             @relation("primary_supplier", fields: [supplier_id], references: [id], onDelete: SetNull)
  secondary_supplier Supplier?            @relation("secondary_supplier", fields: [secondary_supplier_id], references: [id], onDelete: SetNull)
  movements         InventoryMovement[]
  reservations      InventoryReservation[]
  losses            InventoryLoss[]
  purchase_order_items PurchaseOrderItem[]
  audit_logs        InventoryAuditLog[]

  @@index([clinic_id, quantity, minimum_level])
  @@index([clinic_id, status])
  @@index([clinic_id, expiry_date])
  @@map("inventory_items")
}

model InventoryMovement {
  id                    String                @id @default(uuid())
  item_id               String
  clinic_id             String
  type                  InventoryMovementType
  quantity              Int
  unit_cost             Decimal?              @db.Decimal(12, 2)
  ocr_source            String?
  ocr_data              Json?
  ocr_validated         Boolean               @default(false)
  ocr_validated_by      String?
  ocr_validated_by2     String?
  ocr_validated_at      DateTime?
  notes                 String?
  patient_id            String?
  appointment_id        String?
  protocol_id           String?
  reservation_id        String?
  loss_type             InventoryLossType?
  purchase_order_item_id String?
  performed_by          String
  created_at            DateTime              @default(now())

  item InventoryItem @relation(fields: [item_id], references: [id], onDelete: Restrict)

  @@index([item_id, created_at])
  @@index([clinic_id, type, created_at])
  @@map("inventory_movements")
}

model Supplier {
  id             String   @id @default(uuid())
  clinic_id      String
  name           String
  document       String?
  email          String?
  phone          String?
  contact_name   String?
  address        String?
  website        String?
  payment_terms  String?
  lead_time_days Int      @default(7)
  notes          String?
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  deleted_at     DateTime?

  primary_items   InventoryItem[] @relation("primary_supplier")
  secondary_items InventoryItem[] @relation("secondary_supplier")
  purchase_orders PurchaseOrder[]
  clinic          Clinic          @relation(fields: [clinic_id], references: [id], onDelete: Restrict)

  @@index([clinic_id, is_active])
  @@map("suppliers")
}

model PurchaseOrder {
  id                   String               @id @default(uuid())
  clinic_id            String
  supplier_id          String?
  status               PurchaseOrderStatus  @default(SUGGESTED)
  urgency              PurchaseOrderUrgency @default(LOW)
  total_amount         Decimal              @db.Decimal(12, 2) @default(0)
  justification        String?
  requested_by_user_id String?
  approved_by_user_id  String?
  sent_at              DateTime?
  received_at          DateTime?
  notes                String?
  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt

  supplier Supplier?           @relation(fields: [supplier_id], references: [id], onDelete: SetNull)
  items    PurchaseOrderItem[]
  clinic   Clinic              @relation(fields: [clinic_id], references: [id], onDelete: Restrict)

  @@index([clinic_id, status])
  @@index([clinic_id, urgency])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                   String   @id @default(uuid())
  purchase_order_id    String
  item_id              String
  quantity_requested   Int
  quantity_received    Int?
  unit_cost_estimated  Decimal? @db.Decimal(12, 2)
  unit_cost_actual     Decimal? @db.Decimal(12, 2)
  notes                String?

  purchase_order PurchaseOrder @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade)
  item           InventoryItem @relation(fields: [item_id], references: [id], onDelete: Restrict)

  @@map("purchase_order_items")
}

model InventoryReservation {
  id                 String                     @id @default(uuid())
  clinic_id          String
  item_id            String
  patient_id         String?
  appointment_id     String?
  protocol_id        String?
  quantity_reserved  Int
  status             InventoryReservationStatus @default(ACTIVE)
  reserved_at        DateTime                   @default(now())
  consumed_at        DateTime?
  cancelled_at       DateTime?
  created_by_user_id String

  item   InventoryItem @relation(fields: [item_id], references: [id], onDelete: Restrict)
  clinic Clinic        @relation(fields: [clinic_id], references: [id], onDelete: Restrict)

  @@index([clinic_id, status])
  @@index([item_id, status])
  @@map("inventory_reservations")
}

model InventoryLoss {
  id                  String            @id @default(uuid())
  clinic_id           String
  item_id             String
  quantity            Int
  loss_type           InventoryLossType @default(OTHER)
  estimated_cost      Decimal           @db.Decimal(12, 2) @default(0)
  reason              String
  photo_url           String?
  registered_by_user_id String
  created_at          DateTime          @default(now())

  item   InventoryItem @relation(fields: [item_id], references: [id], onDelete: Restrict)
  clinic Clinic        @relation(fields: [clinic_id], references: [id], onDelete: Restrict)

  @@index([clinic_id, loss_type])
  @@index([clinic_id, created_at])
  @@map("inventory_losses")
}

model InventoryAuditLog {
  id            String               @id @default(uuid())
  clinic_id     String
  item_id       String?
  action        InventoryAuditAction
  actor_user_id String?
  before_json   Json?
  after_json    Json?
  created_at    DateTime             @default(now())

  item   InventoryItem? @relation(fields: [item_id], references: [id], onDelete: SetNull)
  clinic Clinic         @relation(fields: [clinic_id], references: [id], onDelete: Restrict)

  @@index([clinic_id, created_at])
  @@index([item_id, created_at])
  @@map("inventory_audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 8 — COMUNICAÇÃO INTERNA
// ─────────────────────────────────────────────────────────────────────────────

model CommunicationChannel {
  id         String                   @id @default(uuid())
  clinic_id  String
  name       String
  type       CommunicationChannelType
  is_active  Boolean                  @default(true)
  created_at DateTime                 @default(now())

  clinic   Clinic                 @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  messages CommunicationMessage[]

  @@index([clinic_id, type])
  @@map("communication_channels")
}

model CommunicationMessage {
  id         String          @id @default(uuid())
  channel_id String
  clinic_id  String
  sender_id  String
  content    String
  priority   MessagePriority @default(NORMAL)
  is_read    Boolean         @default(false)
  read_at    DateTime?
  created_at DateTime        @default(now())
  deleted_at DateTime?

  channel CommunicationChannel @relation(fields: [channel_id], references: [id], onDelete: Restrict)
  sender  User                 @relation(fields: [sender_id], references: [id], onDelete: Restrict)

  @@index([channel_id, created_at])
  @@index([clinic_id, priority, is_read])
  @@map("communication_messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 9 — FORMULÁRIOS INTELIGENTES
// ─────────────────────────────────────────────────────────────────────────────

model FormTemplate {
  id          String    @id @default(uuid())
  clinic_id   String
  title       String
  description String?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  fields    FormField[]
  responses FormResponse[]

  @@index([clinic_id, is_active])
  @@map("form_templates")
}

model FormField {
  id          String  @id @default(uuid())
  template_id String
  label       String
  type        String // TEXT | NUMBER | SELECT | MULTISELECT | DATE | BOOLEAN
  options     Json?
  is_required Boolean @default(false)
  order       Int     @default(0)

  template FormTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@map("form_fields")
}

model FormResponse {
  id          String   @id @default(uuid())
  template_id String
  patient_id  String
  clinic_id   String
  answers     Json
  completed   Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  template FormTemplate @relation(fields: [template_id], references: [id], onDelete: Restrict)
  patient  Patient      @relation(fields: [patient_id], references: [id], onDelete: Restrict)

  @@index([clinic_id, template_id, completed])
  @@map("form_responses")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 10 — EVENT STORE (append-only, particionada via SQL)
// ─────────────────────────────────────────────────────────────────────────────

model Event {
  id            String    @id @default(uuid())
  clinic_id     String
  event_type    String
  event_version String    @default("1.0")
  entity_type   String?
  entity_id     String?
  actor_id      String? // user_id (null = sistema/IA)
  payload       Json      @default("{}")
  processed     Boolean   @default(false)
  processed_at  DateTime?
  created_at    DateTime  @default(now())

  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Restrict)

  @@index([clinic_id, created_at(sort: Desc)])
  @@index([clinic_id, event_type, created_at(sort: Desc)])
  @@index([entity_type, entity_id, created_at(sort: Desc)])
  @@index([processed, created_at])
  @@map("events")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 11 — DECISION PROPOSAL (primitivo central do AYRON)
// ─────────────────────────────────────────────────────────────────────────────

model DecisionProposal {
  id            String                 @id @default(uuid())
  clinic_id     String
  proposal_type DecisionProposalType
  priority      CognitivePriority      @default(P2_OPTIMIZATION)
  risk_level    RiskLevel              @default(LOW)
  status        DecisionProposalStatus @default(PENDING_APPROVAL)

  // raciocínio da IA
  context         String
  analysis        String
  ai_reasoning    String
  proposed_action Json
  expected_impact Json
  confidence      Float

  // explicabilidade e auditoria
  data_sources       Json
  data_snapshot_hash String?
  ai_model_version   String?

  // governança
  required_role    UserRole
  expires_at       DateTime?
  created_by_agent String // "ClinicalAgent" | "FinanceAgent" | etc.

  // ciclo de vida
  approved_by       String?
  rejection_reason  String?
  modification_note String?
  approved_at       DateTime?
  executed_at       DateTime?
  execution_result  Json?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  clinic   Clinic @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  approver User?  @relation("Approver", fields: [approved_by], references: [id], onDelete: SetNull)

  @@index([clinic_id, status, priority])
  @@index([clinic_id, status, expires_at])
  @@index([clinic_id, proposal_type, created_at])
  @@map("decision_proposals")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 12 — AUDITORIA IMUTÁVEL
// Imutabilidade garantida por trigger PostgreSQL (003_audit_immutability.sql)
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id                 String      @id @default(uuid())
  clinic_id          String?
  organization_id    String?
  actor_id           String?
  actor_role         UserRole?
  action             AuditAction
  entity_type        String?
  entity_id          String?
  proposal_id        String?
  metadata           Json        @default("{}")
  data_before        Json?
  data_after         Json?
  data_snapshot_hash String?
  ip_address         String?
  session_id         String?
  ai_model_version   String?
  created_at         DateTime    @default(now())

  actor User? @relation(fields: [actor_id], references: [id], onDelete: SetNull)

  @@index([clinic_id, created_at(sort: Desc)])
  @@index([actor_id, created_at(sort: Desc)])
  @@index([entity_type, entity_id, created_at(sort: Desc)])
  @@index([action, created_at(sort: Desc)])
  @@map("audit_logs")
}

model AiActionLog {
  id            String   @id @default(uuid())
  clinic_id     String
  agent_name    String
  model_version String?
  input_summary String
  output_type   String
  output_id     String?
  confidence    Float?
  latency_ms    Int?
  tokens_used   Int?
  cost_usd      Float?
  success       Boolean  @default(true)
  error_message String?
  created_at    DateTime @default(now())

  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Restrict)

  @@index([clinic_id, agent_name, created_at])
  @@index([success, created_at])
  @@map("ai_action_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 13 — MEMÓRIA COGNITIVA (V6)
// ─────────────────────────────────────────────────────────────────────────────

model CognitiveMemory {
  id              String                       @id @default(uuid())
  clinic_id       String
  patient_id      String?
  memory_type     MemoryType
  memory_text     String
  // embedding       Unsupported("vector(1536)")? -- requires pgvector, deferred
  relevance_score Float                        @default(0.5)
  source_events   Json?
  is_active       Boolean                      @default(true)
  created_at      DateTime                     @default(now())
  updated_at      DateTime                     @updatedAt
  expires_at      DateTime?

  clinic  Clinic   @relation(fields: [clinic_id], references: [id], onDelete: Restrict)
  patient Patient? @relation(fields: [patient_id], references: [id], onDelete: SetNull)

  @@index([clinic_id, memory_type, is_active])
  @@index([patient_id, memory_type])
  @@map("cognitive_memory")
}

model BehaviorPattern {
  id             String   @id @default(uuid())
  clinic_id      String
  user_id        String?
  pattern_type   String
  description    String
  confidence     Float    @default(0.5)
  sample_count   Int      @default(1)
  pattern_data   Json     @default("{}")
  detected_at    DateTime @default(now())
  last_confirmed DateTime @default(now())
  is_active      Boolean  @default(true)

  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Restrict)

  @@index([clinic_id, pattern_type, is_active])
  @@map("behavior_patterns")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 14 — DIGITAL TWIN E ANALYTICS (V8)
// ─────────────────────────────────────────────────────────────────────────────

model DigitalTwinSnapshot {
  id                     String   @id @default(uuid())
  clinic_id              String
  snapshot_type          String // DAILY_STATE | SIMULATION | SCENARIO
  simulation_data        Json
  prediction_window_days Int      @default(30)
  confidence             Float    @default(0.5)
  scenario_description   String?
  created_at             DateTime @default(now())

  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Restrict)

  @@index([clinic_id, snapshot_type, created_at(sort: Desc)])
  @@map("digital_twin_snapshots")
}

model ClinicMetricDaily {
  id                     String   @id @default(uuid())
  clinic_id              String
  metric_date            DateTime
  appointments_scheduled Int      @default(0)
  appointments_completed Int      @default(0)
  appointments_missed    Int      @default(0)
  appointments_cancelled Int      @default(0)
  new_patients           Int      @default(0)
  returning_patients     Int      @default(0)
  revenue_total          Decimal  @default(0) @db.Decimal(12, 2)
  avg_consultation_min   Float?
  occupation_rate        Float?
  clinic_health_score    Float?
  score_breakdown        Json?
  created_at             DateTime @default(now())

  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Restrict)

  @@unique([clinic_id, metric_date])
  @@index([clinic_id, metric_date(sort: Desc)])
  @@map("clinic_metrics_daily")
