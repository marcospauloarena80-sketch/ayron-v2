// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 15 — FEATURE FLAGS E NOTIFICAÇÕES
// ─────────────────────────────────────────────────────────────────────────────

model FeatureFlag {
  id         String         @id @default(uuid())
  clinic_id  String
  flag       FeatureFlagKey
  enabled    Boolean        @default(false)
  config     Json?          @default("{}")
  enabled_at DateTime?
  updated_by String?
  updated_at DateTime       @updatedAt

  clinic Clinic @relation(fields: [clinic_id], references: [id], onDelete: Cascade)

  @@unique([clinic_id, flag])
