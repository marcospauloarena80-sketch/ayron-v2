{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@ayron/types": ["./packages/types/src/index.ts"],
      "@ayron/ui": ["./packages/ui/src/index.ts"],
      "@ayron/events": ["./packages/events/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "build"]
}
